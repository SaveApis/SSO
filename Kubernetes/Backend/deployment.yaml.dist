apiVersion: apps/v1
kind: Deployment
metadata:
  name: backend
  labels:
    app: backend
spec:
  replicas: 3
  selector:
    matchLabels:
      app: backend
  template:
    metadata:
      name: backend
      labels:
        app: backend
    spec:
      containers:
        - name: backend
          image: registry.digitalocean.com/saveapis/sso:${VERSION}
          imagePullPolicy: IfNotPresent
          env:
            - name: ASPNETCORE_ENVIRONMENT
              value: ${ENVIRONMENT}
            - name: ASPNETCORE_HTTP_PORTS
              value: "8080"
            - name: jwt_key
              valueFrom:
                secretKeyRef:
                  name: jwt
                  key: key
            - name: jwt_issuer
              value: SSO-${ENVIRONMENT}
            - name: jwt_audience
              value: SSO-${ENVIRONMENT}
            - name: jwt_expiration
              value: "24"
            - name: hangfire_redis_name
              value: SSO-${ENVIRONMENT}
            - name: hangfire_redis_host
              value: redis.sso-${ENVIRONMENT}.svc.cluster.local
            - name: hangfire_redis_port
              value: "6379"
            - name: hangfire_redis_database
              value: "0"
            - name: hangfire_redis_prefix
              value: "sso:hangfire:"
            - name: db_mysql_name
              value: SSO-${ENVIRONMENT}
            - name: db_mysql_host
              valueFrom:
                secretKeyRef:
                  name: mysql
                  key: host
            - name: db_mysql_port
              valueFrom:
                secretKeyRef:
                  name: mysql
                  key: port
            - name: db_mysql_user
              valueFrom:
                secretKeyRef:
                  name: mysql
                  key: user
            - name: db_mysql_password
              valueFrom:
                secretKeyRef:
                  name: mysql
                  key: password
            - name: db_mysql_database
              valueFrom:
                secretKeyRef:
                  name: mysql
                  key: database
            - name: smtp_enabled
              value: "true"
            - name: smtp_host
              valueFrom:
                secretKeyRef:
                  name: smtp
                  key: host
            - name: smtp_port
              valueFrom:
                secretKeyRef:
                  name: smtp
                  key: port
            - name: smtp_username
              valueFrom:
                secretKeyRef:
                  name: smtp
                  key: user
            - name: smtp_password
              valueFrom:
                secretKeyRef:
                  name: smtp
                  key: password
            - name: smtp_enable_ssl
              value: "true"
          ports:
            - containerPort: 8080
              protocol: TCP
      restartPolicy: Always
      