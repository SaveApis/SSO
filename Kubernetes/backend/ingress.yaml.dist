apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: sso
  annotations:
    nginx.ingress.kubernetes.io/rewrite-target: /
    cert-manager.io/cluster-issuer: letsencrypt
spec:
  ingressClassName: nginx
  tls:
    - hosts:
        - ${HOST}
      secretName: sso-tls
  rules:
    - host: ${HOST}
      http:
        paths:
          - path: /backend
            pathType: Prefix
            backend:
              service:
                name: backend
                port:
                  number: 80
