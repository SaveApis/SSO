GRAPHQL {{url}}
Authorization: Bearer {{token}}

mutation($id: String!) {
    activateProject(id: $id) {
        id
        createdAt
        updatedAt
        name
        description
        active
        users {
            id
            createdAt
            updatedAt
            firstName
            lastName
            email
            phone
            userName
            role
            active
        }
    }
}

{
  "id": "test"
}