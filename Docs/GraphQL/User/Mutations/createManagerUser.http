GRAPHQL {{url}}
Authorization: Bearer {{token}}

mutation($dto: UserCreateDtoInput!) {
    createManagerUser(dto: $dto) {
        id
        createdAt
        updatedAt
        firstName
        lastName
        email
        phone
        userName
        role
        active
    }
}

{
  "dto": {
    "firstName": "Felix",
    "lastName": "Manager",
    "email": "felix.manager@saveapis.com",
    "userName": "felix.manager"
  }
}