GRAPHQL {{url}}
Authorization: Bearer {{token}}

mutation($id: UUID!) {
    activateUser(id: $id) {
        id
        createdAt
        updatedAt
        firstName
        lastName
        email
        phone
        userName
        role
        active
    }
}

